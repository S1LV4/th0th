# ============================================
# th0th - Environment Configuration
# ============================================
# Copy this file to .env and configure as needed
# For Docker: these values are used by docker-compose.yml
# ============================================

# ----------------------------------------------------------------------------
# Docker Image Configuration
# ----------------------------------------------------------------------------
# Use specific version tags (e.g., api-0.1.0) or latest
TH0TH_API_IMAGE=s1lv4/th0th-ai:api-latest
TH0TH_MCP_IMAGE=s1lv4/th0th-ai:mcp-latest

# ----------------------------------------------------------------------------
# API Configuration
# ----------------------------------------------------------------------------
TH0TH_API_PORT=3333
NODE_ENV=production

# ----------------------------------------------------------------------------
# Database Paths (inside container: /data)
# ----------------------------------------------------------------------------
VECTOR_DB_PATH=./data/chroma
CACHE_DB_PATH=./data/cache.db
KEYWORD_DB_PATH=./data/keyword.db
EMBEDDING_CACHE_DB_PATH=./data/embedding-cache.db

# ----------------------------------------------------------------------------
# Logging & Metrics
# ----------------------------------------------------------------------------
LOG_LEVEL=info
ENABLE_METRICS=true

# ----------------------------------------------------------------------------
# Cache Configuration
# ----------------------------------------------------------------------------
L1_CACHE_MAX_SIZE=104857600  # 100MB in bytes
L1_CACHE_TTL=300             # 5 minutes
L2_CACHE_MAX_SIZE=524288000  # 500MB in bytes
L2_CACHE_TTL=3600            # 1 hour

# ----------------------------------------------------------------------------
# Compression
# ----------------------------------------------------------------------------
MIN_TOKENS_FOR_COMPRESSION=100
TARGET_COMPRESSION_RATIO=0.7  # 70% reduction

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
REQUESTS_PER_MINUTE=60
TOKENS_PER_MINUTE=100000

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
MAX_INPUT_LENGTH=50000
SANITIZE_INPUTS=true

# ----------------------------------------------------------------------------
# Embedding Providers Configuration
# ----------------------------------------------------------------------------

# === Ollama (Local - Default) ===
# For Docker: use http://host.docker.internal:11434
# For local dev: use http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding
OLLAMA_EMBEDDING_DIMENSIONS=4096

# Alternative Ollama models:
# OLLAMA_EMBEDDING_MODEL=bge-m3
# OLLAMA_EMBEDDING_DIMENSIONS=1024

# === Mistral Embeddings (Cloud) ===
MISTRAL_API_KEY=
# Text embeddings - General purpose (1024 dimensions)
MISTRAL_TEXT_EMBEDDING_MODEL=mistral-embed
# Code embeddings - Optimized for code (1536D default, up to 3072D)
MISTRAL_CODE_EMBEDDING_MODEL=codestral-embed

