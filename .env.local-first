# ========================================
# TH0TH - 100% LOCAL-FIRST CONFIGURATION
# ========================================
# No external service dependencies.
# Only requires Ollama running locally.
#
# Setup:
#   ./scripts/setup-local-first.sh
#   cp .env.local-first .env
#   bun run start:api
# ========================================

# === DATABASES (Local Only) ===
VECTOR_DB_PATH=./data/chroma
CACHE_DB_PATH=./data/cache.db
KEYWORD_DB_PATH=./data/keyword.db

# === LOCAL EMBEDDINGS (Ollama) ===
# Ollama must be running on localhost:11434
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Start: ollama serve
# Recommended models:
#   ollama pull nomic-embed-text:latest   (768D, good for general text)
#   ollama pull all-minilm:latest         (384D, fast and lightweight)
#   ollama pull mxbai-embed-large:latest  (1024D, higher quality)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3:latest
OLLAMA_EMBEDDING_DIMENSIONS=1024

# === EXTERNAL SERVICES DISABLED ===
# No external API dependencies
# Uncomment and configure if you want remote fallback
# MISTRAL_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# COHERE_API_KEY=

# === CACHE (Local) ===
L1_CACHE_MAX_SIZE=104857600
L1_CACHE_TTL=300
L2_CACHE_MAX_SIZE=524288000
L2_CACHE_TTL=3600

# === COMPRESSION (Local rule-based) ===
MIN_TOKENS_FOR_COMPRESSION=100
TARGET_COMPRESSION_RATIO=0.7

# === RATE LIMITING ===
REQUESTS_PER_MINUTE=120
TOKENS_PER_MINUTE=200000

# === SECURITY ===
MAX_INPUT_LENGTH=50000
SANITIZE_INPUTS=true

# === LOGGING ===
LOG_LEVEL=info
ENABLE_METRICS=true

# === EMBEDDING CACHE (Local) ===
EMBEDDING_CACHE_DB_PATH=./data/embedding-cache.db
